{
  "name": "@sdux-vault/stackblitz-examples",
  "version": "0.0.1",
  "private": true,
  "description": "SDuX Vault StackBlitz example projects",
  "author": "Cedar Sith<sduxvault@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdux-vault/stackblitz-examples.git"
  },
  "homepage": "https://www.sdux-vault.com",
  "workspaces": [
    "stackblitz/angular/demo-*"
  ],
  "watch": {
    "test:tools": {
      "patterns": [
        "tools"
      ],
      "extensions": "js,mjs",
      "quiet": true,
      "legacyWatch": true,
      "delay": 1000,
      "runOnChangeOnly": false
    }
  },
  "scripts": {
    "copy": "node tools/global.mjs",
    "copy:angular": "node tools/global.mjs --language=angular",
    "copy:react": "node tools/global.mjs --language=react",
    "docs:coverage": "eslint . --no-warn-ignored",
    "format:all": "prettier --config ./.prettierrc --write .",
    "format:check": "prettier --config ./.prettierrc --check .",
    "format:fix": "pretty-quick --staged",
    "lint": "eslint . --no-warn-ignored",
    "prepare": "husky",
    "scaffold": "node tools/scaffold.mjs",
    "scaffold:angular": "node tools/scaffold.mjs --language=angular",
    "scaffold:react": "node tools/scaffold.mjs --language=react",
    "test": "npm run test:tools",
    "test:coverage": "run-s test:coverage:clean test:tools:coverage",
    "test:coverage:clean": "rimraf coverage",
    "test:tools": "node --experimental-vm-modules node_modules/jasmine/bin/jasmine.js --config=tools/jasmine.node.json",
    "test:tools:coverage": "c8 --all --include='tools/shared/**/*.class.mjs' --reporter=text --reporter=html --reports-dir=coverage/tools node --experimental-vm-modules node_modules/jasmine/bin/jasmine.js --config=tools/jasmine.node.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm run test:coverage && npm run docs:coverage",
    "watch:tools": "npm-watch test:tools"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,scss,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^20.5.0",
    "@angular-eslint/eslint-plugin-template": "^20.5.0",
    "@angular-eslint/template-parser": "^20.5.0",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/compiler-cli": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@sdux-vault/core": "latest",
    "@sdux-vault/core-extensions-angular": "latest",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "c8": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^50.6.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jasmine": "^5.12.0",
    "lint-staged": "^15.2.0",
    "npm-run-all": "^4.1.5",
    "npm-watch": "^0.13.0",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.8"
  }
}

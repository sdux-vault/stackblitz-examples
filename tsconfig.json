{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "preserve",
    "baseUrl": ".",
    "paths": {
      "@sdux-vault/*": ["node_modules/@sdux-vault/*"]
    }
  },
  "include": ["stackblitz/**/*.ts"],
  "exclude": [
    "stackblitz/deno/**",
    "stackblitz/svelte/**/vite.config.ts",
    "stackblitz/vue/**"
  ]
}

echo "Running lint + format + docs pre-commit..."

npx lint-staged || {
  printf "\n\nERROR: Lint issues were found in the committed files. Please address them before proceeding.\n\n\n\n"
  exit 1
}

npm run docs:coverage
DOC_EXIT_CODE=$?

if [ $DOC_EXIT_CODE -ne 0 ]; then
  printf "\n\nWarning: Doc issues were found in the committed files. Please address them before proceeding.\n\n"
  echo "Docs exit code: $DOC_EXIT_CODE"
fi

npm run format:fix || {
  printf "\n\nERROR: Format:fix issues were found in the committed files. Please address them before proceeding.\n\n\n\n"
  exit 1
}


echo "Pre-commit checks complete."
